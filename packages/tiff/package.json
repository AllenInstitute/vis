{
    "name": "@alleninstitute/vis-tiff",
    "version": "0.0.1",
    "private": true,
    "description": "A small WebGPU TIFF viewer for the browser",
    "source": "src/index.ts",
    "main": "dist/main.js",
    "types": "dist/types.d.ts",
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "parcel build --no-cache",
        "dev": "parcel watch --port 1240",
        "demo": "parcel serve example/index.html --port 1242",
        "coverage": "vitest run --coverage",
        "changelog": "git-cliff -o changelog.md"
    },
    "keywords": [
        "webgpu",
        "tiff",
        "viewer"
    ],
    "license": "BSD-3-Clause",
    "dependencies": {
        "tiff": "^7.1.3",
        "webgpu-utils": "^0.2.0"
    },
    "devDependencies": {
        "typescript": "^5.0.0",
        "@webgpu/types": "^0.1.69"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/AllenInstitute/vis.git"
    },
    "packageManager": "pnpm@9.14.2"
}
