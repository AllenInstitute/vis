{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["react", "vitest", "import", "typescript"],
    "env": {
        "browser": true,
        "es2021": true,
        "vitest": true
    },
    "settings": {
        "react": {
            "version": "18"
        }
    },
    "ignorePatterns": [
        "build",
        "dist",
        "node_modules",
        "*.d.ts",
        "graphql.schema.json",
        "cms-graphql.schema.json",
        "sips-graphql.schema.json",
        "generated-schema-types.ts",
        "cms-generated-schema-types.ts",
        "sips-generated-schema-types.ts",
        "src/applications/ppdc/**/gen.*"
    ],
    "rules": {
        "import/no-cycle": "error",
        "import/no-self-import": "error",
        "import/no-duplicates": "error",
        "import/no-named-as-default": "error"
    }
}
